{
  "name": "@yosemite-crew/design-tokens",
  "version": "0.1.0",
  "private": true,
  "description": "Shared semantic design tokens for Yosemite Crew — consumed by web and mobile",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./css": "./dist/tokens.css",
    "./web": {
      "import": "./dist/web.mjs",
      "require": "./dist/web.js",
      "types": "./dist/web.d.ts"
    },
    "./mobile": {
      "import": "./dist/mobile.mjs",
      "require": "./dist/mobile.js",
      "types": "./dist/mobile.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
