# ─────────────────────────────────────────────────────────────────────────────
# CONTRIBUTOR SETUP — choose one tier below
# ─────────────────────────────────────────────────────────────────────────────
#
# TIER 1 — UI / frontend-only work (zero secrets needed)
# ───────────────────────────────────────────────────────
# Set NEXT_PUBLIC_DISABLE_AUTH_GUARD=true and leave all other keys blank.
# Auth guards are skipped entirely on localhost; every page renders without
# a real login. Use this for component work, bug fixes, tests, and styling.
#
# TIER 2 — Full-stack work (hit the real dev API)
# ────────────────────────────────────────────────
# Uncomment the TIER 2 block below. These are the shared dev Cognito pool
# credentials — they are NOT secrets (they ship in every deployed browser
# bundle). They point at devapi.yosemitecrew.com and isolated dev data only.
# Prod pool IDs are never shared; they are injected by Amplify at deploy time.
# ─────────────────────────────────────────────────────────────────────────────

# ── API + Auth (shared dev environment — safe to commit, these are public identifiers) ──
# Cognito pool IDs are NOT secrets: they ship in every deployed browser bundle.
# These point at devapi.yosemitecrew.com and isolated dev data only — never prod.
NEXT_PUBLIC_BASE_URL="https://devapi.yosemitecrew.com/"
NEXT_PUBLIC_COGNITO_USERPOOLID="eu-central-1_hxzTCq5oY"
NEXT_PUBLIC_COGNITO_CLIENTID="2aaosvrhi2ukh6unle6gcn46en"
NEXT_PUBLIC_DISABLE_AUTH_GUARD=false
# Sign in with your email via OTP at localhost:3000/signin.

# ── UI-only mode (no login, no API needed) ────────────────────────────────────
# For component/styling work only — override these two lines in your local .env:
# NEXT_PUBLIC_BASE_URL="http://localhost:4000/"
# NEXT_PUBLIC_DISABLE_AUTH_GUARD=true

# ── Optional integrations (leave blank if not needed) ────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_STREAM_API_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_SANDBOX_PUBLISH=""

# ── Prod pool — never filled by contributors; injected by Amplify at deploy ───
NEXT_PUBLIC_COGNITO_USERPOOLID_PROD=""
NEXT_PUBLIC_COGNITO_CLIENTID_PROD=""

# ── Server-side keys — only needed for local backend-adjacent work ────────────
STRIPE_KEY=""
SANDBOX_SECRET=""
SANDBOX_PUBLISH=""

# ── Development overrides ────────────────────────────────────────────────────
# NEXT_PUBLIC_DISABLE_AUTH_GUARD: skips ProtectedRoute + OrgGuard on localhost
# only. Has no effect on deployed environments. Set above per tier.

# Override org type for UI flows (testing non-hospital templates).
# Accepted values: HOSPITAL | BOARDER | BREEDER | GROOMER
NEXT_PUBLIC_ORG_TYPE_OVERRIDE=

# ── Analytics (optional, safe to leave blank) ────────────────────────────────
NEXT_PUBLIC_POSTHOG_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Documenso (optional) ─────────────────────────────────────────────────────
# Origin of the self-hosted Documenso instance (no trailing slash).
# Added to CSP frame-src so the Doc Signing portal iframe loads.
# Example: https://sign.yourdomain.com
NEXT_PUBLIC_DOCUMENSO_HOST=

# ── Feature flags ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APPOINTMENT_REVAMP=true
