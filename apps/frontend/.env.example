NEXT_PUBLIC_BASE_URL="http://localhost:4000/"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_COGNITO_USERPOOLID=""
NEXT_PUBLIC_COGNITO_CLIENTID=""
NEXT_PUBLIC_STREAM_API_KEY=""
NEXT_PUBLIC_SANDBOX_PUBLISH=""


# extra keys not used
NEXT_PUBLIC_COGNITO_USERPOOLID_PROD=""
NEXT_PUBLIC_COGNITO_CLIENTID_PROD=""
STRIPE_KEY=""
SANDBOX_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
SANDBOX_PUBLISH=""





# Development: Override auth guards (ProtectedRoute, OrgGuard, and local developer fallback)
# This only applies on localhost / 127.0.0.1. It is ignored on deployed environments.
NEXT_PUBLIC_DISABLE_AUTH_GUARD=false

# Development: Override organization type for UI flows (testing non-hospital templates)
# Accepted values: HOSPITAL | BOARDER | BREEDER | GROOMER
NEXT_PUBLIC_ORG_TYPE_OVERRIDE=

NEXT_PUBLIC_POSTHOG_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Origin of the self-hosted Documenso instance (no trailing slash).
# Added to CSP frame-src so the Doc Signing portal iframe loads.
# Example: https://sign.yourdomain.com
NEXT_PUBLIC_DOCUMENSO_HOST=

# Feature flag: enable the appointment experience revamp.
# Covers the new central modal layout (Add + View overview) and future revamp phases.
# Set to true to activate new flows. Defaults to false — existing side-drawer flows remain active.
NEXT_PUBLIC_APPOINTMENT_REVAMP=true
