{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "node ./scripts/run-jest.mjs",
    "test:unit": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci",
    "test:coverage": "jest --coverage",
    "test:a11y": "jest --ci --maxWorkers=2 --runTestsByPath src/app/__tests__/components/Calendar/Task/TaskSlot.test.tsx src/app/__tests__/components/Calendar/common/Slot.test.tsx src/app/__tests__/components/DataTable/InvoiceTable.test.tsx src/app/__tests__/components/Header/GuestHeader.test.tsx src/app/__tests__/components/Inputs/Datepicker/index.test.tsx src/app/__tests__/components/Inputs/Dropdown/Dropdown.test.tsx src/app/__tests__/components/Inputs/Dropdown/LabelDropdown.test.tsx src/app/__tests__/components/Inputs/FileInput.test.tsx src/app/__tests__/components/Inputs/FormInput.test.tsx src/app/__tests__/components/Inputs/FormInputPass.test.tsx src/app/__tests__/components/Inputs/Search/index.test.tsx src/app/__tests__/components/Inputs/SearchDropdown/index.test.tsx src/app/__tests__/components/Inputs/Timepicker/index.test.tsx src/app/__tests__/components/UploadImage/DocUploader.test.tsx src/app/__tests__/components/UploadImage/UploadImage.test.tsx src/app/__tests__/pages/Finance/Sections/InvoiceInfo.test.tsx src/app/__tests__/pages/ForgotPassword.test.tsx src/app/__tests__/pages/SignIn/SignIn.test.tsx src/app/__tests__/pages/SignUp.test.tsx src/app/__tests__/pages/legal/TrustCenter.test.tsx src/app/__tests__/ui/layout/RouteAnnouncer.test.tsx src/app/__tests__/ui/layout/SkipLink.test.tsx src/app/__tests__/ui/overlays/Loader/YosemiteLoader.test.tsx src/app/__tests__/ui/tables/GenericTable.test.tsx --forceExit",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "chromatic": "chromatic --build-script-name=storybook:build --exit-zero-on-changes",
    "e2e:smoke": "playwright test e2e/smoke.spec.ts",
    "e2e:a11y": "playwright test e2e/a11y.spec.ts",
    "e2e:auth": "playwright test e2e/auth-flow.spec.ts",
    "e2e:playwright": "playwright test",
    "e2e": "pnpm run test:a11y && pnpm run e2e:playwright",
    "e2e:ci:smoke": "E2E_WEB_SERVER_COMMAND='pnpm build && next start -p 3001 -H 127.0.0.1' playwright test e2e/smoke.spec.ts",
    "e2e:ci:a11y": "E2E_WEB_SERVER_COMMAND='pnpm build && next start -p 3001 -H 127.0.0.1' playwright test e2e/a11y.spec.ts",
    "e2e:ci:auth": "E2E_WEB_SERVER_COMMAND='pnpm build && next start -p 3001 -H 127.0.0.1' playwright test e2e/auth-flow.spec.ts",
    "e2e:ci:playwright": "E2E_WEB_SERVER_COMMAND='pnpm build && next start -p 3001 -H 127.0.0.1' playwright test",
    "e2e:ci": "pnpm run test:a11y && pnpm run e2e:ci:playwright",
    "e2e:headed": "pnpm run test:a11y && playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "check:bundle-budgets": "node ./scripts/check-bundle-budgets.mjs",
    "report:build-routes": "node ./scripts/export-build-report.mjs",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@calcom/embed-react": "^1.5.3",
    "@stripe/connect-js": "^3.3.31",
    "@stripe/react-connect-js": "^3.3.31",
    "@testing-library/user-event": "^14.6.1",
    "@tiptap/extension-underline": "^3.24.0",
    "@tiptap/react": "^3.24.0",
    "@tiptap/starter-kit": "^3.24.0",
    "amazon-cognito-identity-js": "^6.3.15",
    "axios": "1.17.0",
    "classnames": "^2.5.1",
    "dompurify": "^3.4.11",
    "framer-motion": "^12.18.1",
    "libphonenumber-js": "^1.12.31",
    "next": "15.5.18",
    "posthog-js": "^1.372.10",
    "react": "^19.1.1",
    "react-datepicker": "^8.7.0",
    "react-dom": "^19.1.1",
    "react-icons": "5.3.0",
    "react-toastify": "^11.0.5",
    "recharts": "^2.15.1",
    "stream-chat": "^9.25.0",
    "stream-chat-react": "^13.11.0",
    "validator": "^13.15.22",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/eslintrc": "^3",
    "@iconify/react": "^6.0.0",
    "@playwright/test": "^1.55.0",
    "@storybook/addon-a11y": "^9.1.20",
    "@storybook/addon-docs": "^9.1.20",
    "@storybook/nextjs-vite": "^9.1.20",
    "@storybook/react": "^9.1.20",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20",
    "@types/react": "^19.1.1",
    "@types/react-datepicker": "^7.0.0",
    "@types/react-dom": "^19.1.1",
    "@yosemite-crew/design-tokens": "workspace:^",
    "@yosemite-crew/fhir": "workspace:^",
    "@yosemite-crew/types": "workspace:^",
    "chromatic": "^16.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "eslint-plugin-sonarjs": "^3.0.7",
    "jest": "^29.7.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.6",
    "storybook": "^9.1.20",
    "tailwindcss": "^4.1.17",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
