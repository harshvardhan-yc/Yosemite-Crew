      "node-forge": "1.4.0",
      "@modelcontextprotocol/sdk": "1.26.0",
      "validator": "13.15.22",
      "axios": "1.15.0",
      "handlebars": "4.7.9",
      "ajv@6": "6.14.0",
      "ajv@7": "8.18.0",
      "ajv@8": "8.18.0",
      "glob@10.4.5": "10.5.0",
