{
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "verify": "pnpm run lint && pnpm run type-check && pnpm run test && pnpm run build",
    "lint-staged": "lint-staged",
    "commitlint": "commitlint --edit",
    "check:secrets": "secretlint \"**/*\" --maskSecrets"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@secretlint/secretlint-rule-no-dotenv": "^11.3.0",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.0",
    "eslint": "^9.33.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.2.5",
    "secretlint": "^11.3.0",
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@8.15.6",
  "name": "yosemitecrew",
  "pnpm": {
    "overrides": {
      "qs": "6.14.1",
      "tar": "7.5.7",
      "node-forge": "1.3.2",
      "@modelcontextprotocol/sdk": "1.25.2",
      "validator": "13.15.22",
      "axios": "1.13.2",
      "react-native-worklets": "^0.7.0",
      "glob@10.4.5": "10.5.0",
      "glob@11.0.3": "11.1.0",
      "jws@3.2.2": "3.2.3",
      "jws@4.0.0": "4.0.1",
      "fast-xml-parser": "5.3.4",
      "mdast-util-to-hast": "13.2.1",
      "lodash": "4.17.23"
    }
  }
}
